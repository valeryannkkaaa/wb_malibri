# WB API token (Promotion + Analytics)
WB_API_TOKEN=

# Portal session (shared with wb-portal for /advert auth)
PORTAL_SESSION_SECRET=

# PostgreSQL (when integrated with portal)
DATABASE_URL=postgresql://user:pass@localhost:5432/wb_portal

# Sync
WB_ADVERT_SYNC_INTERVAL_MIN=15
WB_ADVERT_REQUEST_PAUSE_SEC=1.2

# Pilot
WB_ADVERT_PILOT_CONFIG=../data/pilot/config.yaml
WB_ADVERT_PILOT_DATA=../data/pilot
